---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Cases' }
];
---

<Layout title="Cases | Sabine Booij" description="Praktijkvoorbeelden en casestudy's">
  <LowHero title="Cases & Praktijkvoorbeelden" subtitle="Concrete resultaten uit het veld" breadcrumbs={breadcrumbs} />

  <section class="cases-content">
    <div class="container">
      <div class="cases-grid">
        <div class="case-item">
          <div class="case-label">Politie</div>
          <h3>Communicatie onder Druk</h3>
          <p><strong>Situatie:</strong> Agenten worstelden met effectieve communicatie in tense situaties, wat tot escalaties leidde.</p>
          <p><strong>Aanpak:</strong> 8-weken maatwerktraject met realistische scenario's.</p>
          <p><strong>Resultaat:</strong> 35% minder escalaties, beter burger-politiecontact.</p>
        </div>

        <div class="case-item">
          <div class="case-label">Zorg</div>
          <h3>Agressiehantering</h3>
          <p><strong>Situatie:</strong> Medewerkers worstelden met agressief gedrag van patiënten.</p>
          <p><strong>Aanpak:</strong> De-escalatietraining met praktijkscenario's.</p>
          <p><strong>Resultaat:</strong> Veiliger werkklimaat, minder burnout.</p>
        </div>

        <div class="case-item">
          <div class="case-label">Luchtvaart</div>
          <h3>Crisiscommunicatie</h3>
          <p><strong>Situatie:</strong> Teams hadden onvoldoende voorbereiding voor crisissituaties.</p>
          <p><strong>Aanpak:</strong> Intensieve crisistrainingen met realistische scenario's.</p>
          <p><strong>Resultaat:</strong> Betere crisisrespons, sterker teamwerk.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

