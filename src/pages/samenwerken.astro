---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Samenwerken' }
];
---

<Layout title="Samenwerken | Sabine Booij" description="Hoe ik uw organisatie ondersteun">
  <LowHero title="Samenwerken" subtitle="Hoe ik uw organisatie ondersteun" breadcrumbs={breadcrumbs} />

  <section class="samenwerken-content">
    <div class="container">
      <div class="collab-grid">
        <div class="collab-card">
          <div class="collab-icon">⚡</div>
          <h3>Workshop</h3>
          <p>Korte sessie rondom één thema. Ideaal voor bewustwording en teamontwikkeling.</p>
        </div>

        <div class="collab-card">
          <div class="collab-icon">📋</div>
          <h3>Trainingstraject</h3>
          <p>Meerdere trainingsdagen met intake, scenarioontwikkeling en evaluatie.</p>
        </div>

        <div class="collab-card">
          <div class="collab-icon">🎯</div>
          <h3>Organisatieontwikkeling</h3>
          <p>Langdurige samenwerking: training, coaching, assessments en advies.</p>
        </div>

        <div class="collab-card">
          <div class="collab-icon">👤</div>
          <h3>Coaching</h3>
          <p>Één-op-één begeleiding voor leidinggevenden en professionals.</p>
        </div>
      </div>

      <div class="collab-note">
        <p><strong>Elke organisatie is anders.</strong> Ik werk uitsluitend met maatwerk. Na een kennismakingsgesprek ontvangt u een voorstel op maat.</p>
      </div>
    </div>
  </section>
</Layout>

