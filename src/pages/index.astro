---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sabine Booij | Maatwerkoplossingen Communicatie & Gedrag" description="Sabine Booij: specialist in communicatie, gedrag en besluitvorming onder druk. Maatwerktrainingen en coaching voor politie, defensie, zorg en bedrijven.">

  <!-- Hero Section -->
  <section id="home" class="hero">
    <div class="hero-background">
      <div class="hero-accent-1"></div>
      <div class="hero-accent-2"></div>
      <div class="hero-accent-3"></div>
    </div>

    <div class="container">
      <div class="hero-wrapper">
        <div class="hero-content">
          <div class="logo-full"><img src="/images/logo-sb-light-full.png"></div>
          <div class="hero-badge">Specialist | Consultant | Expert</div>
          <h1 class="hero-h1">Professionals die handelen onder druk.</h1>
          <p class="hero-subtitle">Communicatie die werkt. Training die blijft hangen. Voor organisaties waar veiligheid en effectiviteit tellen.</p>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="stat-value">12+</span>
              <span class="stat-label">Jaar Ervaring</span>
            </div>
            <div class="hero-stat">
              <span class="stat-value">500+</span>
              <span class="stat-label">Professionals</span>
            </div>
            <div class="hero-stat">
              <span class="stat-value">30+</span>
              <span class="stat-label">Organisaties</span>
            </div>
          </div>

          <div class="hero-cta">
            <a href="#contact" class="btn btn-primary-hero">Plan een kennismakingsgesprek</a>
            <a href="#expertise" class="btn btn-secondary-hero">Bekijk mijn expertise</a>
          </div>
        </div>

        <div class="hero-image-container">
          <div class="hero-image-frame">
            <img src="/images/terrorisme.jpg" alt="Sabine Booij - Specialist" class="hero-image" />
            <div class="hero-image-overlay"></div>
            <div class="hero-badge-accent">Expert in<br />Communicatie<br />&amp; Gedrag</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Logos -->
  <section class="trust-logos">
    <div class="container">
      <h3>Vertrouwd door organisaties</h3>
      <div class="logos-grid">
        <div class="logo-badge">Politie</div>
        <div class="logo-badge">Defensie</div>
        <div class="logo-badge">KLM</div>
        <div class="logo-badge">Transavia</div>
        <div class="logo-badge">ABN AMRO</div>
        <div class="logo-badge">LUMC</div>
        <div class="logo-badge">Zorg</div>
        <div class="logo-badge">Overheid</div>
      </div>
    </div>
  </section>

  <!-- Why Sabine -->
  <section class="why-sabine">
    <div class="container why-sabine__grid">
      <div class="why-sabine__left">
        <span class="section-label">WAAROM IK</span>
        <h2 class="section-title">Ik ben geen trainer. Ik ben specialist in gedrag en communicatie onder druk.</h2>
      </div>
      <div class="why-sabine__right">
        <div class="proof-points">
          <div class="proof-item">
            <div class="proof-icon">✓</div>
            <p>12+ jaar ervaring in hoog-risico en complexe omgevingen</p>
          </div>
          <div class="proof-item">
            <div class="proof-icon">✓</div>
            <p>Specialist in gedrag & communicatie</p>
          </div>
          <div class="proof-item">
            <div class="proof-icon">✓</div>
            <p>Trainingsacteur, assessor én ontwikkelaar van maatwerktrainingen</p>
          </div>
          <div class="proof-item">
            <div class="proof-icon">✓</div>
            <p>Praktijkgerichte aanpak, geen theorie uit een boekje</p>
          </div>
          <div class="proof-item">
            <div class="proof-icon">✓</div>
            <p>Altijd maatwerk, nooit standaard</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise Grid -->
  <section id="expertise" class="expertise">
    <div class="container">
      <span class="section-label">Expertise</span>
      <h2 class="section-title">Mijn Expertise</h2>
      <p class="section-subtitle">Gespecialiseerd in communicatie, gedrag en besluitvorming onder druk</p>

      <div class="expertise-grid">
        <div class="expertise-card">
          <h4>Communicatie onder Druk</h4>
          <p>Professionals die effectief communiceren wanneer het moeilijk is.</p>
        </div>
        <div class="expertise-card">
          <h4>De-escalatie & Conflicthantering</h4>
          <p>Van escalatie naar verbinding door gerichte communicatie.</p>
        </div>
        <div class="expertise-card">
          <h4>Crisiscommunicatie</h4>
          <p>Handelen en besluitvorming in crisissituaties.</p>
        </div>
        <div class="expertise-card">
          <h4>Leiderschap & Feedback</h4>
          <p>Sterk leiderschap en moeilijke gesprekken voeren.</p>
        </div>
        <div class="expertise-card">
          <h4>Gedragsanalyse</h4>
          <p>Menselijk gedrag begrijpen en beïnvloeden.</p>
        </div>
        <div class="expertise-card">
          <h4>Teamontwikkeling</h4>
          <p>Teams sterker en effectiever laten samenwerken.</p>
        </div>
        <div class="expertise-card">
          <h4>Omgaan met Agressie</h4>
          <p>Hantering van agressief en grensoverschrijdend gedrag.</p>
        </div>
        <div class="expertise-card">
          <h4>Hoog-Risico Incidenten</h4>
          <p>Extreem geweld, terrorisme, gijzelingen, interventies.</p>
        </div>
        <div class="expertise-card">
          <h4>Meldkamertrainingen</h4>
          <p>Specialistische training voor meldkamer-professionals.</p>
        </div>
        <div class="expertise-card">
          <h4>HEAT-Training</h4>
          <p>Operationele trainingen voor hoog-risico situaties.</p>
        </div>
        <div class="expertise-card">
          <h4>Praktijkexamens & Assessments</h4>
          <p>Beoordeling van professionals en trainingsacteur.</p>
        </div>
        <div class="expertise-card">
          <h4>Advies & Scenario-Ontwikkeling</h4>
          <p>Maatwerk trainingen en leertrajecten ontwerpen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="process">
    <div class="container">
      <div class="process__header">
        <span class="section-label">Werkwijze</span>
        <h2 class="section-title">Van vraagstuk naar meetbare gedragsverandering</h2>
      </div>

      <div class="process-steps">
        <div class="process-item">
          <div class="process-num">Stap 1</div>
          <h4>Analyse</h4>
          <p>Ik breng de vraag en de praktijk van uw organisatie in kaart.</p>
        </div>
        <div class="process-item">
          <div class="process-num">Stap 2</div>
          <h4>Ontwikkeling</h4>
          <p>Ik ontwerp een maatwerkprogramma dat aansluit op uw vraagstuk.</p>
        </div>
        <div class="process-item">
          <div class="process-num">Stap 3</div>
          <h4>Training</h4>
          <p>Realistische scenario's, praktijkgericht en op maat gespeeld.</p>
        </div>
        <div class="process-item">
          <div class="process-num">Stap 4</div>
          <h4>Evaluatie</h4>
          <p>Feedback, borging en doorontwikkeling van het geleerde.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cases Section -->
  <section id="cases" class="cases">
    <div class="container">
      <span class="section-label">Cases</span>
      <h2 class="section-title">Praktijkvoorbeelden</h2>
      <p class="section-subtitle">Concrete resultaten uit het veld</p>

      <div class="cases-grid">
        <div class="case-item">
          <div class="case-label">Politie</div>
          <h4>Communicatie onder Druk</h4>
          <div class="case-flow">
            <p><strong>Situatie:</strong> Agenten worstelden met effectieve communicatie in tense situaties, wat tot escalaties leidde.</p>
            <p><strong>Aanpak:</strong> 8-weken maatwerktraject met realistische scenario's en individuele coaching.</p>
            <p><strong>Resultaat:</strong> 35% minder escalaties, beter burger-politiecontact, hogere zelfredzaamheid.</p>
          </div>
        </div>
        <div class="case-item">
          <div class="case-label">Zorg</div>
          <h4>Agressiehantering</h4>
          <div class="case-flow">
            <p><strong>Situatie:</strong> Medewerkers worstelden met agressief gedrag van patiënten en bezoekers.</p>
            <p><strong>Aanpak:</strong> De-escalatietraining met praktijkscenario's gebaseerd op reële situaties.</p>
            <p><strong>Resultaat:</strong> Veiliger werkklimaat, betere agressiehantering, minder burnout.</p>
          </div>
        </div>
        <div class="case-item">
          <div class="case-label">Luchtvaart</div>
          <h4>Crisiscommunicatie</h4>
          <div class="case-flow">
            <p><strong>Situatie:</strong> Teams hadden onvoldoende voorbereiding en training voor crisissituaties.</p>
            <p><strong>Aanpak:</strong> Intensieve crisistrainingen met realistische scenario's en assessments.</p>
            <p><strong>Resultaat:</strong> Betere crisisrespons, effectievere commandostructuur, sterker teamwerk.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Branches Section -->
  <section id="branches" class="branches">
    <div class="container">
      <span class="section-label">Branches</span>
      <h2 class="section-title">Sectors & Branches</h2>
      <p class="section-subtitle">Ik werk met organisaties uit diverse sectoren</p>

      <div class="branches-grid">
        <div class="branch-card">
          <h4>Politie</h4>
          <p>Communicatie onder druk, de-escalatie, crisiscommunicatie</p>
        </div>
        <div class="branch-card">
          <h4>Defensie</h4>
          <p>Hoog-risico training, operationele voorbereiding</p>
        </div>
        <div class="branch-card">
          <h4>Justitie</h4>
          <p>Leiderschap, gedragsanalyse, coaching</p>
        </div>
        <div class="branch-card">
          <h4>Zorg</h4>
          <p>Agressiehantering, teamontwikkeling, de-escalatie</p>
        </div>
        <div class="branch-card">
          <h4>Luchtvaart</h4>
          <p>Crisiscommunicatie, praktijkexamens</p>
        </div>
        <div class="branch-card">
          <h4>Overheid</h4>
          <p>Leiderschap, communicatie, samenwerking</p>
        </div>
        <div class="branch-card">
          <h4>Beveiliging</h4>
          <p>Hoog-risico incidenten, gedragsanalyse</p>
        </div>
        <div class="branch-card">
          <h4>Bedrijfsleven</h4>
          <p>Feedback, leiderschap, teamontwikkeling</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Collaborate Section -->
  <section id="collaborate" class="collaborate">
    <div class="container">
      <span class="section-label">Samenwerken</span>
      <h2 class="section-title">Samenwerken</h2>
      <p class="section-subtitle">Hoe ik uw organisatie ondersteun</p>

      <div class="collab-grid">
        <div class="collab-card">
          <div class="collab-icon">⚡</div>
          <h4>Workshop</h4>
          <p>Korte sessie rondom één thema. Ideaal voor bewustwording, teamontwikkeling of eerste stap.</p>
        </div>
        <div class="collab-card">
          <div class="collab-icon">📋</div>
          <h4>Trainingstraject</h4>
          <p>Meerdere trainingsdagen met intake, scenarioontwikkeling en evaluatie. Maatwerk op maat.</p>
        </div>
        <div class="collab-card">
          <div class="collab-icon">🎯</div>
          <h4>Organisatieontwikkeling</h4>
          <p>Langdurige samenwerking: training, coaching, assessments en advies voor structurele verbeteringen.</p>
        </div>
        <div class="collab-card">
          <div class="collab-icon">👤</div>
          <h4>Coaching</h4>
          <p>Één-op-één begeleiding voor leidinggevenden en professionals op communicatie en gedrag.</p>
        </div>
      </div>

      <div class="collaborate-note">
<p><strong>Elke organisatie is anders.</strong> Ik werk uitsluitend met maatwerk. Na een kennismakingsgesprek ontvangt u een voorstel op maat, afgestemd op uw doelstellingen en resultaten.</p>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <img src="/images/sabine.png" alt="Sabine Booij" />
        </div>
        <div class="about-content">
          <span class="section-label">Over</span>
          <h2 class="section-title">Over Sabine Booij</h2>
          <p class="lead">Sabine is specialist in communicatie, gedrag en besluitvorming onder druk. Met meer dan 12 jaar praktijkervaring in hoog-risico en complexe omgevingen, helpt zij organisaties professioneel handelen wanneer het moeilijk is.</p>

          <h3>Ervaring</h3>
          <p>Trainer, trainingsacteur, assessor, coach en consultant. Werkt met Politie, Defensie, Justitie, Zorg, Luchtvaart, Overheid en Bedrijfsleven.</p>

          <h3>Aanpak</h3>
          <p>Ik geloof dat de kwaliteit van communicatie het verschil maakt tussen escalatie en verbinding. Door realistische scenario's en praktijkgerichte begeleiding help ik professionals duurzaam te groeien.</p>

          <h3>Resultaat</h3>
          <p>Veiligere organisaties, betere communicatie, sterkere teams, effectievere samenwerking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-final">
    <div class="container">
      <h2 class="section-title">Klaar om te starten?</h2>
      <p>Laten we bespreken hoe ik uw organisatie kan helpen beter te communiceren en handelen onder druk.</p>
      <a href="#contact" class="btn btn-primary-large">Neem contact op</a>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
      <span class="section-label">Contact</span>
      <h2 class="section-title">Contact</h2>
      <div class="contact-grid">
        <div class="contact-direct">
          <h4>Direct contact</h4>
          <div class="contact-item">
            <strong>E-mail</strong>
            <a href="mailto:info@sabinnovation.nl">info@sabinnovation.nl</a>
          </div>
          <div class="contact-item">
            <strong>Telefoon</strong>
            <a href="tel:+31622337262">+31 6 223 37 262</a>
          </div>
        </div>
        <div class="contact-form">
          <h4>Stuur een bericht</h4>
          <form>
            <div class="form-group">
              <label for="name">Uw naam *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="email">E-mailadres *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="organization">Organisatie *</label>
              <input type="text" id="organization" name="organization" required />
            </div>
            <div class="form-group">
              <label for="message">Beschrijf uw uitdaging *</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary-large">Verstuur</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
