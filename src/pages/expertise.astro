---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';
---

<Layout title="Expertise | Sabine Booij" description="Mijn expertise in communicatie, gedrag en training">
  <LowHero title="Mijn Expertise" subtitle="Gespecialiseerd in communicatie, gedrag en besluitvorming onder druk" />

  <section class="expertise-content">
    <div class="container">
      <div class="expertise-list">
        <div class="expertise-item">
          <h3>Communicatie onder Druk</h3>
          <p>Professionals die effectief communiceren wanneer het moeilijk is.</p>
        </div>
        <div class="expertise-item">
          <h3>De-escalatie & Conflicthantering</h3>
          <p>Van escalatie naar verbinding door gerichte communicatie.</p>
        </div>
        <div class="expertise-item">
          <h3>Crisiscommunicatie</h3>
          <p>Handelen en besluitvorming in crisissituaties.</p>
        </div>
        <div class="expertise-item">
          <h3>Leiderschap & Feedback</h3>
          <p>Sterk leiderschap en moeilijke gesprekken voeren.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

