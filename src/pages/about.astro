---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Over Sabine' }
];
---

<Layout title="Over Sabine | Sabine Booij" description="Leer meer over Sabine Booij, specialist in communicatie, gedrag en training">
  <LowHero title="Over Sabine Booij" subtitle="12+ jaar expertise in communicatie onder druk" breadcrumbs={breadcrumbs} />

  <section class="about-content">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Wie ben ik?</h2>
          <p>Ik ben Sabine Booij, specialist in communicatie, gedrag en besluitvorming onder druk. Met meer dan 12 jaar praktijkervaring help ik organisaties en professionals beter te communiceren wanneer het moeilijk is.</p>

          <h3>Achtergrond</h3>
          <p>Mijn werk brengt me in hoog-risico omgevingen: politie, defensie, justitie, zorg en luchtvaart. Ik ben trainer, trainingsacteur, assessor en ontwerper van maatwerktrainingen. Ik geloof dat kwaliteit van communicatie het verschil maakt tussen escalatie en verbinding.</p>

          <h3>Aanpak</h3>
          <p>Realistische scenario's, praktijkgerichte begeleiding en daadwerkelijke gedragsverandering. Geen standaard trainingen — elk traject is maatwerk, afgestemd op uw organisatie en context.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

