---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Branches' }
];
---

<Layout title="Branches | Sabine Booij" description="Sectoren waarin ik werkzaam ben">
  <LowHero title="Branches & Sectoren" subtitle="Ik werk met organisaties uit diverse sectoren" breadcrumbs={breadcrumbs} />

  <section class="branches-content">
    <div class="container">
      <div class="branches-grid">
        <div class="branch-card">
          <h3>Politie</h3>
          <p>Communicatie onder druk, de-escalatie, crisiscommunicatie</p>
        </div>
        <div class="branch-card">
          <h3>Defensie</h3>
          <p>Hoog-risico training, operationele voorbereiding</p>
        </div>
        <div class="branch-card">
          <h3>Zorg</h3>
          <p>Agressiehantering, teamontwikkeling, de-escalatie</p>
        </div>
        <div class="branch-card">
          <h3>Luchtvaart</h3>
          <p>Crisiscommunicatie, praktijkexamens</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

