---
import Layout from '../layouts/Layout.astro';
import LowHero from '../components/LowHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Werkwijze' }
];
---

<Layout title="Werkwijze | Sabine Booij" description="Hoe ik work: een gestructureerd proces voor duurzame verandering">
  <LowHero title="Mijn Werkwijze" subtitle="Een gestructureerd proces voor duurzame verandering" breadcrumbs={breadcrumbs} />

  <section class="werkwijze-content">
    <div class="container">
      <div class="process-steps">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Analyse</h3>
          <p>Ik breng uw vraagstuk en praktijksituatie in kaart.</p>
        </div>
        <div class="arrow">→</div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Ontwikkeling</h3>
          <p>Ik ontwerp een uniek maatwerkprogramma.</p>
        </div>
        <div class="arrow">→</div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Training</h3>
          <p>Realistische scenario's en praktijkgerichte aanpak.</p>
        </div>
        <div class="arrow">→</div>
        <div class="step">
          <div class="step-num">4</div>
          <h3>Evaluatie</h3>
          <p>Feedback, borging en doorontwikkeling.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

